{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cleanup-worker",
  "main": "workers/cleanup.ts",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["0 * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "migrations_dir": "drizzle",
      "database_name": "moemail",
      "database_id": "${DATABASE_ID}"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SITE_CONFIG",
      "id": "${KV_NAMESPACE_ID}"
    }
  ]
}
