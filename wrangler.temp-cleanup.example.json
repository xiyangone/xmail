{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xmail-temp-cleanup-worker",
  "main": "workers/temp-account-cleanup.ts",
  "compatibility_date": "2024-03-20",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "vars": {
    "SITE_URL": "https://xymailyx.dpdns.org"
  },
  "kv_namespaces": [
    {
      "binding": "SITE_CONFIG",
      "id": "${KV_NAMESPACE_ID}"
    }
  ]
}
